{
  "name": "qa-portfolio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:public": "playwright test --project=smoke --project=public",
    "test:dashboard": "playwright test --project=dashboard",
    "bdd:gen": "bddgen",
    "test:bdd": "bddgen && playwright test --project=bdd",
    "anonymize": "node scripts/anonymize-allure-portfolio.cjs",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:portfolio": "node scripts/anonymize-allure-portfolio.cjs && allure generate allure-results --clean -o allure-report",
    "test:breton-smartek": "mocha"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.0.0",
    "playwright-bdd": "^8.5.1",
    "selenium-webdriver": "^4.27.0",
    "mocha": "^10.8.0",
    "allure-mocha": "^3.0.0"
  }
}
